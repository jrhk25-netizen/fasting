<!DOCTYPE html>

<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="轻断食">
<meta name="theme-color" content="#0a0a0f">
<title>16:8 轻断食</title>
<link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='22' fill='%230a0a0f'/><text y='72' x='50' text-anchor='middle' font-size='62'>🍵</text></svg>">
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='22' fill='%230a0a0f'/><text y='72' x='50' text-anchor='middle' font-size='62'>🍵</text></svg>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --border: #1e1e2e;
    --fast-color: #6c63ff;
    --eat-color: #00d4aa;
    --text: #e8e8f0;
    --muted: #5a5a72;
    --ring-fast: #6c63ff;
    --ring-eat: #00d4aa;
  }

- { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘Noto Sans SC’, sans-serif;
min-height: 100vh;
min-height: 100dvh;
display: flex;
flex-direction: column;
align-items: center;
overflow-x: hidden;
position: relative;
}

/* Ambient background */
body::before {
content: ‘’;
position: fixed;
top: -30%;
left: 50%;
transform: translateX(-50%);
width: 600px;
height: 600px;
border-radius: 50%;
background: radial-gradient(circle, rgba(108,99,255,0.08) 0%, transparent 70%);
pointer-events: none;
transition: background 1s ease;
z-index: 0;
}

body.eating::before {
background: radial-gradient(circle, rgba(0,212,170,0.08) 0%, transparent 70%);
}

.container {
width: 100%;
max-width: 420px;
padding: 0 24px;
padding-bottom: 40px;
position: relative;
z-index: 1;
}

/* Header */
.header {
text-align: center;
padding-top: 52px;
margin-bottom: 40px;
}

.app-label {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 4px;
color: var(–muted);
text-transform: uppercase;
margin-bottom: 8px;
}

.app-title {
font-size: 22px;
font-weight: 300;
letter-spacing: 2px;
color: var(–text);
}

/* Status badge */
.status-badge {
display: inline-flex;
align-items: center;
gap: 8px;
padding: 6px 16px;
border-radius: 999px;
font-size: 12px;
letter-spacing: 1px;
margin-top: 20px;
transition: all 0.5s ease;
border: 1px solid;
}

.status-badge.fasting {
background: rgba(108,99,255,0.12);
border-color: rgba(108,99,255,0.3);
color: #a8a3ff;
}

.status-badge.eating {
background: rgba(0,212,170,0.12);
border-color: rgba(0,212,170,0.3);
color: #00d4aa;
}

.status-dot {
width: 6px;
height: 6px;
border-radius: 50%;
animation: pulse 2s infinite;
}

.fasting .status-dot { background: #6c63ff; }
.eating .status-dot { background: #00d4aa; }

@keyframes pulse {
0%, 100% { opacity: 1; transform: scale(1); }
50% { opacity: 0.5; transform: scale(0.8); }
}

/* Ring */
.ring-wrapper {
display: flex;
justify-content: center;
margin-bottom: 36px;
}

.ring-container {
position: relative;
width: 240px;
height: 240px;
}

.ring-svg {
width: 240px;
height: 240px;
transform: rotate(-90deg);
}

.ring-track {
fill: none;
stroke: var(–border);
stroke-width: 8;
}

.ring-progress {
fill: none;
stroke-width: 8;
stroke-linecap: round;
stroke-dasharray: 659;
stroke-dashoffset: 659;
transition: stroke-dashoffset 1s ease, stroke 0.5s ease;
filter: drop-shadow(0 0 6px currentColor);
}

.ring-progress.fasting { stroke: var(–ring-fast); }
.ring-progress.eating { stroke: var(–ring-eat); }

.ring-center {
position: absolute;
top: 50%;
left: 50%;
transform: translate(-50%, -50%);
text-align: center;
}

.time-display {
font-family: ‘DM Mono’, monospace;
font-size: 44px;
font-weight: 300;
letter-spacing: -1px;
line-height: 1;
color: var(–text);
}

.time-label {
font-size: 11px;
color: var(–muted);
letter-spacing: 2px;
margin-top: 6px;
text-transform: uppercase;
}

.percent-label {
font-family: ‘DM Mono’, monospace;
font-size: 13px;
color: var(–muted);
margin-top: 4px;
}

/* Info cards */
.cards {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 12px;
margin-bottom: 24px;
}

.card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 16px;
padding: 16px;
}

.card-label {
font-size: 10px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 6px;
font-family: ‘DM Mono’, monospace;
}

.card-value {
font-family: ‘DM Mono’, monospace;
font-size: 18px;
font-weight: 400;
color: var(–text);
}

.card-sub {
font-size: 11px;
color: var(–muted);
margin-top: 2px;
}

.card.highlight-fast { border-color: rgba(108,99,255,0.3); }
.card.highlight-eat { border-color: rgba(0,212,170,0.3); }

/* Schedule bar */
.schedule-section {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 16px;
padding: 20px;
margin-bottom: 24px;
}

.section-title {
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–muted);
font-family: ‘DM Mono’, monospace;
margin-bottom: 16px;
}

.schedule-row {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 10px;
}

.sched-label {
font-size: 12px;
color: var(–muted);
width: 60px;
}

.sched-time {
font-family: ‘DM Mono’, monospace;
font-size: 14px;
color: var(–text);
}

.sched-pill {
font-size: 10px;
padding: 3px 10px;
border-radius: 999px;
letter-spacing: 1px;
}

.sched-pill.fast { background: rgba(108,99,255,0.15); color: #a8a3ff; }
.sched-pill.eat { background: rgba(0,212,170,0.15); color: #00d4aa; }

/* Notification toggle */
.notif-row {
display: flex;
align-items: center;
justify-content: space-between;
padding-top: 12px;
border-top: 1px solid var(–border);
margin-top: 4px;
}

.notif-label {
font-size: 12px;
color: var(–muted);
}

.toggle {
position: relative;
width: 42px;
height: 24px;
}

.toggle input { opacity: 0; width: 0; height: 0; }

.toggle-slider {
position: absolute;
cursor: pointer;
inset: 0;
background: var(–border);
border-radius: 999px;
transition: 0.3s;
}

.toggle-slider::before {
content: ‘’;
position: absolute;
width: 18px;
height: 18px;
left: 3px;
top: 3px;
background: var(–muted);
border-radius: 50%;
transition: 0.3s;
}

.toggle input:checked + .toggle-slider { background: rgba(108,99,255,0.4); }
.toggle input:checked + .toggle-slider::before {
transform: translateX(18px);
background: #6c63ff;
}

/* Settings */
.settings-section {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 16px;
padding: 20px;
margin-bottom: 24px;
}

.setting-row {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 14px;
}

.setting-row:last-child { margin-bottom: 0; }

.setting-label {
font-size: 13px;
color: var(–text);
}

.setting-sub {
font-size: 11px;
color: var(–muted);
margin-top: 2px;
}

.time-input {
background: var(–bg);
border: 1px solid var(–border);
border-radius: 8px;
color: var(–text);
font-family: ‘DM Mono’, monospace;
font-size: 14px;
padding: 6px 10px;
width: 90px;
text-align: center;
-webkit-appearance: none;
}

.time-input:focus { outline: none; border-color: var(–fast-color); }

/* Action buttons */
.actions { display: flex; flex-direction: column; gap: 12px; }

.btn-primary {
width: 100%;
padding: 16px;
border-radius: 14px;
border: none;
font-family: ‘Noto Sans SC’, sans-serif;
font-size: 15px;
font-weight: 500;
cursor: pointer;
transition: all 0.2s ease;
letter-spacing: 1px;
}

.btn-start {
background: linear-gradient(135deg, #6c63ff, #9c7aff);
color: white;
box-shadow: 0 4px 20px rgba(108,99,255,0.3);
}

.btn-start:active { transform: scale(0.98); opacity: 0.9; }

.btn-stop {
background: var(–surface);
border: 1px solid var(–border) !important;
color: var(–muted);
font-size: 13px;
padding: 12px;
}

/* Tips */
.tip-box {
margin-top: 24px;
padding: 16px;
background: var(–surface);
border: 1px solid var(–border);
border-radius: 16px;
font-size: 12px;
color: var(–muted);
line-height: 1.8;
text-align: center;
}

.tip-box strong { color: var(–text); }

/* Toast */
.toast {
position: fixed;
bottom: 40px;
left: 50%;
transform: translateX(-50%) translateY(80px);
background: var(–surface);
border: 1px solid var(–border);
border-radius: 12px;
padding: 12px 20px;
font-size: 13px;
color: var(–text);
transition: transform 0.3s ease;
z-index: 999;
white-space: nowrap;
}

.toast.show { transform: translateX(-50%) translateY(0); }

/* Install hint */
.install-hint {
text-align: center;
font-size: 11px;
color: var(–muted);
margin-top: 32px;
line-height: 1.8;
padding-bottom: 20px;
}

.install-hint strong { color: var(–text); }
</style>

</head>
<body>

<div class="container">
  <div class="header">
    <div class="app-label">Intermittent Fasting</div>
    <div class="app-title">16 · 8 轻断食</div>
    <div class="status-badge fasting" id="statusBadge">
      <span class="status-dot"></span>
      <span id="statusText">断食中</span>
    </div>
  </div>

  <!-- Ring timer -->

  <div class="ring-wrapper">
    <div class="ring-container">
      <svg class="ring-svg" viewBox="0 0 240 240">
        <circle class="ring-track" cx="120" cy="120" r="105"/>
        <circle class="ring-progress fasting" id="ringProgress" cx="120" cy="120" r="105"/>
      </svg>
      <div class="ring-center">
        <div class="time-display" id="timeDisplay">00:00</div>
        <div class="time-label" id="timeLabel">剩余时间</div>
        <div class="percent-label" id="percentLabel">0%</div>
      </div>
    </div>
  </div>

  <!-- Cards -->

  <div class="cards">
    <div class="card highlight-fast">
      <div class="card-label">断食窗口</div>
      <div class="card-value">16<span style="font-size:12px;color:var(--muted)">小时</span></div>
      <div class="card-sub" id="fastWindow">—</div>
    </div>
    <div class="card highlight-eat">
      <div class="card-label">进食窗口</div>
      <div class="card-value">8<span style="font-size:12px;color:var(--muted)">小时</span></div>
      <div class="card-sub" id="eatWindow">—</div>
    </div>
  </div>

  <!-- Schedule -->

  <div class="schedule-section">
    <div class="section-title">今日安排</div>
    <div class="schedule-row">
      <span class="sched-label" style="font-size:12px;color:var(--muted)">🌙 停止进食</span>
      <span class="sched-time" id="schedStop">—</span>
      <span class="sched-pill fast">断食开始</span>
    </div>
    <div class="schedule-row">
      <span class="sched-label" style="font-size:12px;color:var(--muted)">☀️ 开窗时间</span>
      <span class="sched-time" id="schedStart">—</span>
      <span class="sched-pill eat">可以进食</span>
    </div>
    <div class="schedule-row">
      <span class="sched-label" style="font-size:12px;color:var(--muted)">🌙 关窗时间</span>
      <span class="sched-time" id="schedEnd">—</span>
      <span class="sched-pill fast">停止进食</span>
    </div>
    <div class="notif-row">
      <span class="notif-label">🔔 浏览器提醒通知</span>
      <label class="toggle">
        <input type="checkbox" id="notifToggle" onchange="toggleNotifications()">
        <span class="toggle-slider"></span>
      </label>
    </div>
  </div>

  <!-- Settings -->

  <div class="settings-section">
    <div class="section-title">设置进食时间</div>
    <div class="setting-row">
      <div>
        <div class="setting-label">每天开始进食</div>
        <div class="setting-sub">进食窗口开始时间</div>
      </div>
      <input type="time" class="time-input" id="eatStartInput" value="12:00" onchange="updateSchedule()">
    </div>
    <div class="setting-row">
      <div>
        <div class="setting-label">进食截止时间</div>
        <div class="setting-sub">8小时后自动计算</div>
      </div>
      <div class="sched-time" id="eatEndDisplay" style="font-size:14px">20:00</div>
    </div>
  </div>

  <!-- Actions -->

  <div class="actions">
    <button class="btn-primary btn-start" id="mainBtn" onclick="toggleFast()">
      开始计时断食
    </button>
    <button class="btn-primary btn-stop" onclick="resetFast()">重置</button>
  </div>

  <div class="tip-box">
    <strong>断食期间可以喝：</strong><br>
    白水 · 黑咖啡（无糖奶） · 纯茶 · 无热量饮料
  </div>

  <div class="install-hint">
    📱 <strong>保存到主屏幕免登录使用</strong><br>
    iPhone: Safari → 分享 → 添加到主屏幕<br>
    Android: Chrome → 菜单 → 添加到主屏幕
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ── State ──────────────────────────────────────────────
let state = {
  active: false,
  startTime: null,      // timestamp when fast began
  eatStartHour: 12,     // hour
  eatStartMin: 0,       // minute
  notificationsEnabled: false,
  notifTimers: []
};

const FAST_DURATION = 16 * 3600 * 1000;
const EAT_DURATION  =  8 * 3600 * 1000;

// ── Persistence ────────────────────────────────────────
function saveState() {
  localStorage.setItem('if_state', JSON.stringify(state));
}

function loadState() {
  try {
    const saved = JSON.parse(localStorage.getItem('if_state'));
    if (saved) Object.assign(state, saved);
  } catch(e) {}
}

// ── Time helpers ───────────────────────────────────────
function fmt(h, m) {
  return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
}

function fmtMs(ms) {
  if (ms < 0) ms = 0;
  const h = Math.floor(ms / 3600000);
  const m = Math.floor((ms % 3600000) / 60000);
  const s = Math.floor((ms % 60000) / 1000);
  return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
}

// ── Schedule calc ──────────────────────────────────────
function getSchedule() {
  const now = new Date();
  // Eat window start today
  const eatStart = new Date(now);
  eatStart.setHours(state.eatStartHour, state.eatStartMin, 0, 0);

  const eatEnd = new Date(eatStart.getTime() + EAT_DURATION);
  // Fast starts at eatEnd (previous day effectively)
  const fastStart = new Date(eatEnd.getTime() - FAST_DURATION - EAT_DURATION); // eatEnd - 24h = yesterday's eatEnd

  return { eatStart, eatEnd, fastStart: eatEnd }; // fast starts when eating ends
}

function updateSchedule() {
  const val = document.getElementById('eatStartInput').value;
  const [h, m] = val.split(':').map(Number);
  state.eatStartHour = h;
  state.eatStartMin  = m;

  const eatEnd = new Date();
  eatEnd.setHours(h + 8, m, 0, 0);
  document.getElementById('eatEndDisplay').textContent = fmt(eatEnd.getHours(), eatEnd.getMinutes());

  // Update schedule display
  const fastStop = fmt(h, m);  // when fasting ends / eating begins
  const eatStop  = fmt(eatEnd.getHours(), eatEnd.getMinutes());

  // Previous night stop
  const prevH = h === 0 ? 16 + 0 : h < 8 ? 24 + h - 8 : h - 8;
  const prevStop = fmt(prevH, m);

  document.getElementById('schedStop').textContent  = prevStop;
  document.getElementById('schedStart').textContent = fastStop;
  document.getElementById('schedEnd').textContent   = eatStop;
  document.getElementById('fastWindow').textContent = `${prevStop} → ${fastStop}`;
  document.getElementById('eatWindow').textContent  = `${fastStop} → ${eatStop}`;

  saveState();
  scheduleNotifications();
}

// ── Phase detection ────────────────────────────────────
function getCurrentPhase() {
  const now = new Date();
  const nowMin = now.getHours() * 60 + now.getMinutes();
  const eatStartMin = state.eatStartHour * 60 + state.eatStartMin;
  const eatEndMin   = eatStartMin + 8 * 60;

  if (nowMin >= eatStartMin && nowMin < eatEndMin) {
    // Eating window
    const elapsed = (nowMin - eatStartMin) * 60 * 1000 + now.getSeconds() * 1000;
    const remaining = EAT_DURATION - elapsed;
    const pct = elapsed / EAT_DURATION;
    return { phase: 'eating', elapsed, remaining, pct };
  } else {
    // Fasting window
    let fastElapsedMin;
    if (nowMin >= eatEndMin) {
      fastElapsedMin = nowMin - eatEndMin;
    } else {
      fastElapsedMin = (24 * 60 - eatEndMin) + nowMin;
    }
    const elapsed = fastElapsedMin * 60 * 1000 + now.getSeconds() * 1000;
    const remaining = FAST_DURATION - elapsed;
    const pct = Math.min(elapsed / FAST_DURATION, 1);
    return { phase: 'fasting', elapsed, remaining, pct };
  }
}

// ── UI update ──────────────────────────────────────────
function updateUI() {
  const { phase, elapsed, remaining, pct } = getCurrentPhase();
  const isEating = phase === 'eating';

  // Body class
  document.body.className = isEating ? 'eating' : '';

  // Ring
  const ring = document.getElementById('ringProgress');
  const circumference = 659;
  const offset = circumference - pct * circumference;
  ring.style.strokeDashoffset = offset;
  ring.className = `ring-progress ${isEating ? 'eating' : 'fasting'}`;

  // Status badge
  const badge = document.getElementById('statusBadge');
  badge.className = `status-badge ${isEating ? 'eating' : 'fasting'}`;
  document.getElementById('statusText').textContent = isEating ? '进食窗口 🍽' : '断食中 💧';

  // Time display
  const r = remaining < 0 ? 0 : remaining;
  document.getElementById('timeDisplay').textContent = fmtMs(r);
  document.getElementById('timeLabel').textContent   = isEating ? '距关窗' : '距开窗';
  document.getElementById('percentLabel').textContent = `${Math.round(pct * 100)}%`;

  // Button
  const btn = document.getElementById('mainBtn');
  btn.textContent = isEating ? '✅ 进食窗口开放中' : '⏳ 断食进行中';
  btn.className   = `btn-primary ${isEating ? 'btn-eat-active' : 'btn-start'}`;
  btn.style.background = isEating
    ? 'linear-gradient(135deg, #00d4aa, #00b890)'
    : 'linear-gradient(135deg, #6c63ff, #9c7aff)';
  btn.style.boxShadow = isEating
    ? '0 4px 20px rgba(0,212,170,0.3)'
    : '0 4px 20px rgba(108,99,255,0.3)';
}

// ── Notifications ──────────────────────────────────────
async function toggleNotifications() {
  const toggle = document.getElementById('notifToggle');
  if (toggle.checked) {
    if (!('Notification' in window)) {
      showToast('此浏览器不支持通知');
      toggle.checked = false;
      return;
    }
    const perm = await Notification.requestPermission();
    if (perm !== 'granted') {
      showToast('请允许通知权限');
      toggle.checked = false;
      return;
    }
    state.notificationsEnabled = true;
    showToast('✅ 通知已开启');
    scheduleNotifications();
  } else {
    state.notificationsEnabled = false;
    state.notifTimers.forEach(clearTimeout);
    state.notifTimers = [];
    showToast('通知已关闭');
  }
  saveState();
}

function scheduleNotifications() {
  if (!state.notificationsEnabled) return;
  state.notifTimers.forEach(clearTimeout);
  state.notifTimers = [];

  const now = new Date();
  const todayEatStart = new Date(now);
  todayEatStart.setHours(state.eatStartHour, state.eatStartMin, 0, 0);
  const todayEatEnd = new Date(todayEatStart.getTime() + EAT_DURATION);

  function sched(time, title, body) {
    const delay = time - Date.now();
    if (delay > 0 && delay < 24 * 3600 * 1000) {
      const id = setTimeout(() => {
        new Notification(title, { body, icon: '' });
      }, delay);
      state.notifTimers.push(id);
    }
  }

  sched(todayEatStart, '🍽 进食窗口开放！', `现在可以吃东西了，窗口开放至 ${fmt(todayEatEnd.getHours(), todayEatEnd.getMinutes())}`);
  sched(new Date(todayEatEnd.getTime() - 30 * 60000), '⚠️ 进食窗口30分钟后关闭', '记得完成今天的进食');
  sched(todayEatEnd, '🌙 进食窗口关闭', '断食开始，保持水分补充！');
}

// ── Toast ──────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ── Legacy button (now phase-aware) ───────────────────
function toggleFast() {
  const { phase } = getCurrentPhase();
  if (phase === 'eating') {
    showToast('🍽 进食窗口开放中，好好享用！');
  } else {
    showToast('💧 断食中，喝水保持状态！');
  }
}

function resetFast() {
  const eatInput = document.getElementById('eatStartInput');
  eatInput.value = '12:00';
  state.eatStartHour = 12;
  state.eatStartMin  = 0;
  updateSchedule();
  showToast('已重置为 12:00 进食窗口');
}

// ── Init ───────────────────────────────────────────────
loadState();

// Set input
document.getElementById('eatStartInput').value = fmt(state.eatStartHour, state.eatStartMin);
if (state.notificationsEnabled) document.getElementById('notifToggle').checked = true;

updateSchedule();
updateUI();
setInterval(updateUI, 1000);
</script>

